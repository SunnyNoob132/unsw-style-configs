{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "javascript": {
    "formatter": {
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSpacing": true,
      "arrowParentheses": "always",
      "quoteStyle": "single"
    }
  },

  "linter": {
    "enabled": true,

    "rules": {
      "recommended": true,
      "style": {
        "useConst": "error",
        "useNamingConvention": "error",
        "useForOf": "error"
      },

      "suspicious": {
        "noDoubleEquals": "error",
        "noVar": "error"
      }
    }
  }
}
